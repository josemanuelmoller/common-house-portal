{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "regions": ["lhr1"],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/ingest-meetings",
      "schedule": "0 18 * * 1-5"
    },
    {
      "path": "/api/ingest-meetings",
      "schedule": "0 0 * * 2-6"
    },
    {
      "path": "/api/extract-meeting-evidence",
      "schedule": "0 2 * * 2-6"
    },
    {
      "path": "/api/ingest-gmail",
      "schedule": "0 7 * * 1-5"
    },
    {
      "path": "/api/evidence-to-knowledge",
      "schedule": "0 4 * * 1-5"
    },
    {
      "path": "/api/project-operator",
      "schedule": "0 5 * * 1-5"
    },
    {
      "path": "/api/validation-operator",
      "schedule": "0 3 * * 1-5"
    },
    {
      "path": "/api/relationship-warmth",
      "schedule": "0 6 * * 1,4"
    },
    {
      "path": "/api/generate-daily-briefing",
      "schedule": "30 7 * * 1-5"
    },
    {
      "path": "/api/fireflies-sync",
      "schedule": "30 6 * * 1-5"
    },
    {
      "path": "/api/competitive-monitor",
      "schedule": "0 7 * * 1"
    },
    {
      "path": "/api/grant-radar",
      "schedule": "0 7 * * 3"
    }
  ]
}
